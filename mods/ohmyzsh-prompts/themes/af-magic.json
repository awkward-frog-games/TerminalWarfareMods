{
  "id": "af-magic",
  "description": "Ported from oh-my-zsh themes/af-magic.zsh-theme",
  "segments": [
    {
      "text": "▶",
      "fg": "green",
      "bold": true
    },
    {
      "text": " {path}",
      "fg": "cyan"
    },
    {
      "text": " {prompt_char}",
      "fg": "green"
    }
  ],
  "suffix": " "
}
